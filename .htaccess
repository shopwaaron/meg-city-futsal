# GoDaddy / Apache redirects
# Upload this file to the root of your hosting alongside index.html

Options -Indexes
RewriteEngine On

# Redirect old pages to homepage
Redirect 301 /home-.html /
Redirect 301 /programs.html /
Redirect 301 /futsalers.html /
Redirect 301 /meg-city-select.html /
Redirect 301 /about.html /
Redirect 301 /staff.html /
Redirect 301 /contact.html /

# Redirect old register page to external registration
Redirect 301 /register-.html https://megcityfutsal.sportngin.com/register/form/294981733
